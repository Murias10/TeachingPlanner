# Snippet con la configuración común para servir archivos estáticos
(static_files) {
	# Raíz donde está tu app React
	root * /srv

	# Compresión automática
	encode gzip zstd

	# Servir archivos estáticos
	file_server

	# SPA - todas las rutas van a index.html
	try_files {path} /index.html

	# Headers de seguridad globales
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
	}

	# Cache para assets estáticos
	@static path *.ico *.css *.js *.gif *.jpg *.jpeg *.png *.svg *.woff *.woff2 *.ttf *.eot
	header @static Cache-Control "public, max-age=31536000, immutable"
}

# Configuración HTTPS con certificados oficiales de la universidad
{$DOMAIN:localhost} {
	# Usar certificados proporcionados por la universidad
	tls /certs/cert.pem /certs/key.pem

	# Logs
	log {
		output stdout
		format console
		level INFO
	}

	# Reverse proxy para la API
	handle /api/* {
		reverse_proxy {$GATEWAY_SERVICE_HOST:gateway_service}:{$GATEWAY_SERVICE_PORT:8080} {
			# Headers para que los servicios backend sepan la URL real
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# Todo lo demás va a la webapp
	handle {
		import static_files
	}
}
