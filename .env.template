# Plantilla de archivo .env para la configuración de servicios y bases de datos
# Copiar este fichero como .env y ajustar los valores antes de levantar la aplicación

NODE_ENV=production

# VARIABLES DE CONFIGURACIÓN DE LA BASE DE DATOS: PLANNER_DATABASE
PLANNER_DATABASE_ROOT_PASSWORD=rootpassword         # Contraseña del usuario root de MariaDB
PLANNER_DATABASE_DATABASE=planner_db                # Base de datos que se creará al iniciar
PLANNER_DATABASE_USER=planner_user                  # Usuario de la base de datos
PLANNER_DATABASE_PASSWORD=planner_password          # Contraseña del usuario de la base de datos
PLANNER_DATABASE_PORT=3306                          # Puerto estándar para MariaDB
PLANNER_DATABASE_HOST=planner_database              # Nombre del host de la base de datos (nombre del contenedor Docker)

# VARIABLES DE CONFIGURACIÓN DE LA BASE DE DATOS: MANAGEMENT_DATABASE
MANAGEMENT_DATABASE_ROOT_PASSWORD=rootpassword      # Contraseña del usuario root de MariaDB
MANAGEMENT_DATABASE_DATABASE=management_db          # Base de datos que se creará al iniciar
MANAGEMENT_DATABASE_USER=management_user            # Usuario de la base de datos
MANAGEMENT_DATABASE_PASSWORD=management_password    # Contraseña del usuario de la base de datos
MANAGEMENT_DATABASE_PORT=3307                       # Puerto del host (el contenedor usa siempre 3306 internamente)
MANAGEMENT_DATABASE_HOST=management_database        # Nombre del host de la base de datos (nombre del contenedor Docker)

# VARIABLES DE CONFIGURACIÓN DEL MÓDULO: PLANNER_SERVICE
PLANNER_SERVICE_PORT=5001                           # Puerto del servicio del planificador
PLANNER_SERVICE_HOST=planner_service                # Nombre del contenedor del planificador

# VARIABLES DE CONFIGURACIÓN DEL MÓDULO: GATEWAY_SERVICE
GATEWAY_SERVICE_PORT=8080                           # Puerto del gateway (el 80 queda libre para la webapp)
GATEWAY_SERVICE_HOST=gateway_service                # Nombre del contenedor del gateway

# VARIABLES DE CONFIGURACIÓN DEL MÓDULO: USER_SERVICE
USER_SERVICE_PORT=5002                              # Puerto del servicio de usuarios
USER_SERVICE_HOST=user_service                      # Nombre del contenedor del servicio de usuarios

# VARIABLES DE CONFIGURACIÓN DEL MÓDULO: AUTH_SERVICE
AUTH_SERVICE_PORT=5003                              # Puerto del servicio de autenticación
AUTH_SERVICE_HOST=auth_service                      # Nombre del contenedor del servicio de autenticación
AUTH_SERVICE_URL=http://auth_service:5003           # URL interna del auth_service para comunicación entre servicios

# VARIABLES DE CONFIGURACIÓN DE LA WEBAPP
WEBAPP_PORT=80                                      # Puerto externo expuesto por Caddy
WEBAPP_HOST=webapp                                  # Nombre del contenedor de la webapp
DOMAIN=localhost                                    # Dominio para SSL. Con "localhost" sirve en HTTP sin SSL.
                                                    # Con un dominio real (ej. mi-app.example.com) activa HTTPS con el certificado montado.
SERVER_IP=                                          # IP pública del servidor. Necesaria para la lista blanca CORS cuando se accede por IP sin dominio.
FRONTEND_URL=http://localhost:5173                  # URL base del frontend. Usada por user_service para construir los enlaces de activación
                                                    # y recuperación de contraseña en los correos electrónicos.
                                                    # En producción: https://<dominio>

# SEGURIDAD Y AUTENTICACIÓN
JWT_SECRET=                                         # Clave secreta para firmar/verificar tokens JWT. Mínimo 32 caracteres.
                                                    # Generar con: openssl rand -base64 48
ENCRYPTION_KEY=                                     # Clave de 32 bytes en hexadecimal para cifrar tokens de Google OAuth en BD.
                                                    # Generar con: openssl rand -hex 32

# CONFIGURACIÓN DE CORREO ELECTRÓNICO (SMTP)
SMTP_HOST=smtp.gmail.com                            # Servidor SMTP
SMTP_PORT=587                                       # Puerto SMTP
SMTP_USER=tu_email@gmail.com                        # Dirección de correo del remitente
SMTP_PASS=                                          # Contraseña de aplicación (Gmail: 16 caracteres generados en Cuenta → Seguridad → Contraseñas de aplicación)
SMTP_FROM=noreply@tudominio.com                     # Dirección que aparece como remitente en los correos

# CONFIGURACIÓN DE EXPIRACIÓN DE TOKENS DE RECUPERACIÓN DE CONTRASEÑA
PASSWORD_RESET_TOKEN_EXPIRY=1800000                 # Validez del token de recuperación en milisegundos (1800000 = 30 minutos)
PASSWORD_RESET_OTP_EXPIRY=900000                    # Validez del código OTP en milisegundos (900000 = 15 minutos)
PASSWORD_RESET_OTP_COOLDOWN=60000                   # Tiempo mínimo entre solicitudes de OTP en milisegundos (60000 = 1 minuto)

# INTEGRACIÓN CON GOOGLE CALENDAR (OPCIONAL)
GOOGLE_CLIENT_ID=                                   # Client ID del proyecto en Google Cloud Console
GOOGLE_CLIENT_SECRET=                               # Client Secret del proyecto en Google Cloud Console
GOOGLE_REDIRECT_URI=                                # URI de callback OAuth registrada en Google Cloud Console
                                                    # Desarrollo: http://localhost:8080/api/auth/google/callback
                                                    # Producción: https://<dominio>/api/auth/google/callback
GOOGLE_CALENDAR_SYNC_ENABLED=false                  # Activar la integración con Google Calendar (true/false)
