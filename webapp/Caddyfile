# Configuración global
{
	# Certificado por defecto para conexiones sin SNI
	default_sni {$DOMAIN:localhost}
}

# Snippet con la configuración común para servir archivos estáticos
(static_files) {
	# Raíz donde está tu app React
	root * /srv

	# Compresión automática
	encode gzip zstd

	# Servir archivos estáticos
	file_server

	# SPA - todas las rutas van a index.html
	try_files {path} /index.html

	# Headers de seguridad globales
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-XSS-Protection "1; mode=block"
	}

	# Cache para assets estáticos
	@static path *.ico *.css *.js *.gif *.jpg *.jpeg *.png *.svg *.woff *.woff2 *.ttf *.eot
	header @static Cache-Control "public, max-age=31536000, immutable"
}

# Configuración para el dominio y la IP
{$DOMAIN:localhost}, {$SERVER_IP:} {
	tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem

	# Logs (debe estar fuera de handle)
	log {
		output stdout
		format console
	}

	# Reverse proxy para la API
	handle /api/* {
		reverse_proxy {$GATEWAY_SERVICE_HOST:gateway_service}:{$GATEWAY_SERVICE_PORT:8080}
	}

	# Todo lo demás va a la webapp
	handle {
		import static_files
	}
}
